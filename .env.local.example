# ============================================================================
# TradeVault — Environment Variables
# Copy this file to .env.local and fill in real values. Never commit
# .env.local — it should already be in .gitignore.
# ============================================================================

# --- Supabase --------------------------------------------------------------
# Project Settings > API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-only, NEVER expose to the client/browser.
# Used by the MT5 webhook route to bypass RLS with its own secret-based auth.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Groq AI -----------------------------------------------------------------
# https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# --- Telegram Bot ------------------------------------------------------------
# Create a bot via @BotFather on Telegram to get a token.
# Get your chat_id by messaging @userinfobot or via the Bot API getUpdates call.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
# Set to "true" once the above two are configured, to show the connected
# indicator in the header. Purely cosmetic — does not affect functionality.
NEXT_PUBLIC_TELEGRAM_ENABLED=false

# --- MT5 Webhook --------------------------------------------------------------
# Shared secret your MT5 Expert Advisor must send in the webhook payload's
# "secret" field. Generate a long random string and keep it private.
MT5_WEBHOOK_SECRET=generate-a-long-random-secret-here

# --- App ----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
